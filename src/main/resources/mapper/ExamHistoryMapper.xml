<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.platform.mapper.ExamHistoryMapper">
    
    <select id="selectByUserId" resultType="com.student.platform.entity.ExamHistory">
        SELECT * FROM exam_history WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>
    
</mapper>
