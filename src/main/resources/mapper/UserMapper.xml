<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.platform.mapper.UserMapper">
    
    <select id="findByUsername" resultType="com.student.platform.entity.User">
        SELECT * FROM user WHERE username = #{username}
    </select>
    
    <select id="findByEmail" resultType="com.student.platform.entity.User">
        SELECT * FROM user WHERE email = #{email}
    </select>
    
    <select id="findByPhone" resultType="com.student.platform.entity.User">
        SELECT * FROM user WHERE phone = #{phone}
    </select>
    
</mapper>
