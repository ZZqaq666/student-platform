<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.platform.mapper.ExamQaHistoryMapper">
    
    <select id="findByUserId" resultType="com.student.platform.entity.ExamQaHistory">
        SELECT * FROM exam_qa_history WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>
    
    <select id="findRecentByLimit" resultType="com.student.platform.entity.ExamQaHistory">
        SELECT * FROM exam_qa_history ORDER BY created_at DESC LIMIT #{limit}
    </select>
    
</mapper>
